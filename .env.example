# Copy to .env and fill in once the Google Apps Script Web App is deployed
# (see ../kuriausity-forms-backend/apps-script/Code.gs). All three vars should
# point at the SAME deployed Web App URL -- it's a single script that routes
# internally by the `formType` field (see src/lib/submitForm.ts for the exact
# payload shape sent to it).

VITE_INQUIRY_ENDPOINT=
VITE_CONSULTANT_APPLICATION_ENDPOINT=
VITE_REVIEW_ENDPOINT=
