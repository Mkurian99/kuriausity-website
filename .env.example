# Copy to .env and fill in once the Google Cloud Function backend is deployed
# (see ../kuriausity-forms-backend). All three vars should point at the SAME
# deployed function URL -- it's a single Cloud Function that routes internally
# by the `formType` field (see src/lib/submitForm.ts for the exact payload
# shape sent to it).

VITE_INQUIRY_ENDPOINT=
VITE_CONSULTANT_APPLICATION_ENDPOINT=
VITE_REVIEW_ENDPOINT=
